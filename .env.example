# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/solaris_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Server
PORT=8080

# Security
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRATION=86400000

# Frontend
FRONTEND_URL=http://localhost:5173

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM=no-reply@solarismanager.com

# TusFacturas fiscal provider (optional — org credentials are stored per organization)
# Same endpoint for Plan API DEV (sandbox) and production; TusFacturas has no separate sandbox URL.
TUSFACTURAS_BASE_URL=https://www.tusfacturas.app/app/api/v2/facturacion/nuevo

# Per-organization TusFacturas credentials are NOT set here.
# Configure them in Admin > Fiscal settings as JSON in the API key field:
# {"apikey":"YOUR_APIKEY","apitoken":"YOUR_APITOKEN","usertoken":"YOUR_USERTOKEN"}
