# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/solaris_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Server
PORT=8080

# Security
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRATION=86400000

# Frontend
FRONTEND_URL=http://localhost:5173

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM=no-reply@solarismanager.com

# TusFacturas fiscal provider (optional — org credentials are stored per organization)
# Same endpoint for Plan API DEV (sandbox) and production; TusFacturas has no separate sandbox URL.
TUSFACTURAS_BASE_URL=https://www.tusfacturas.app/app/api/v2/facturacion/nuevo

# Per-organization TusFacturas credentials are NOT set here.
# Configure them in Admin > Fiscal settings as JSON in the API key field:
# {"apikey":"YOUR_APIKEY","apitoken":"YOUR_APITOKEN","usertoken":"YOUR_USERTOKEN"}

# --- Verifactu native (Spain) ---
# Sandbox (local / preproduction). VERIFACTU_PROD_* vars are NOT used in sandbox mode.
VERIFACTU_SANDBOX_ENABLED=false
# VERIFACTU_QR_URL=https://prewww1.aeat.es/wlpl/TIKE-CONT/ValidarQR
# VERIFACTU_SERVICE_URL=https://prewww1.aeat.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP
# VERIFACTU_NIF=B12345678
# VERIFACTU_CERT_PATH=C:/secrets/verifactu-sandbox.p12
# VERIFACTU_CERT_PASSWORD=your-p12-password
# Dry-run: builds XML/QR/HTML locally without POSTing to AEAT (good for layout tests)
VERIFACTU_INTEGRATION_TEST_ENABLED=false

# Production (only when going live — do not set for sandbox tests)
# VERIFACTU_PRODUCTION_ENABLED=false
# VERIFACTU_PROD_QR_URL=https://www2.agenciatributaria.gob.es/wlpl/TIKE-CONT/ValidarQR
# VERIFACTU_PROD_SERVICE_URL=https://www1.agenciatributaria.gob.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP

# Per-organization Verifactu credentials (fiscal_api_key JSON):
# {"provider":"verifactu_native","nif":"B12345678","serie":1,"certBase64":"...","certPassword":"..."}
